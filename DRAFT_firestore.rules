rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 2: Relationship Mapping - Employee
    function isValidEmployee(data) {
      return data.firstName is string && data.firstName.size() >= 1 && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() >= 1 && data.lastName.size() <= 100 &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 200 &&
             data.department is string && data.department.size() >= 1 &&
             data.position is string && data.position.size() >= 1 &&
             data.status in ['active', 'on-leave', 'terminated'] &&
             data.salary is number && data.salary >= 0 &&
             data.createdAt == (resource == null ? request.time : existing().createdAt) &&
             data.updatedAt == request.time;
    }

    // Phase 2: Relationship Mapping - Activity Log
    function isValidActivityLog(data) {
      return data.actionType in ['CREATE', 'UPDATE', 'DELETE'] &&
             data.entityId is string && data.entityId.size() <= 128 &&
             data.entityType == 'Employee' &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time &&
             data.description is string && data.description.size() <= 500;
    }

    // 1. Employees Collection
    match /employees/{employeeId} {
      allow list: if isVerified();
      allow get: if isVerified();
      
      allow create: if isVerified() && 
                      isValidId(employeeId) && 
                      isValidEmployee(incoming()) && 
                      incoming().keys().hasAll(['firstName', 'lastName', 'email', 'department', 'position', 'status', 'salary', 'createdAt', 'updatedAt']) &&
                      incoming().keys().size() >= 9;

      allow update: if isVerified() && 
                      isValidEmployee(incoming()) && (
                        // Standard update: Allow changing fields while maintaining immutables
                        incoming().diff(existing()).affectedKeys().hasAny(['firstName', 'lastName', 'email', 'phone', 'department', 'position', 'salary', 'hireDate', 'status', 'photoUrl', 'bio', 'updatedAt']) &&
                        incoming().createdAt == existing().createdAt
                      );

      allow delete: if isVerified();
    }

    // 2. Activity Logs Collection
    match /activity_logs/{logId} {
      allow list: if isVerified();
      allow get: if isVerified();
      
      allow create: if isVerified() && 
                      isValidActivityLog(incoming());
      
      // Activity logs are immutable
      allow update, delete: if false;
    }
  }
}
